root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.rs]
indent_style = space
indent_size = 4

[*.{toml,yaml,yml,json,md}]
indent_style = space
indent_size = 2

[docs/spec/weregopher-electron-transformation-runtime-spec.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
