{
  "$defs": {
    "AdapterId": {
      "description": "A durable adapter identifier.",
      "maxLength": 255,
      "minLength": 1,
      "pattern": "^(?!.*\\.\\.)[a-z0-9](?:[a-z0-9._-]{0,253}[a-z0-9])?$",
      "type": "string"
    },
    "ApplicationFamilyId": {
      "description": "A durable application-family identifier, such as `openai.chatgpt`.",
      "maxLength": 255,
      "minLength": 1,
      "pattern": "^(?!.*\\.\\.)[a-z0-9](?:[a-z0-9._-]{0,253}[a-z0-9])?$",
      "type": "string"
    },
    "AuthorizedTransformRuleRef": {
      "additionalProperties": false,
      "description": "One semantic transform rule declared by a static adapter artifact.",
      "properties": {
        "rule_digest": {
          "$ref": "#/$defs/Sha256Digest"
        }
      },
      "required": [
        "rule_digest"
      ],
      "type": "object"
    },
    "Sha256Digest": {
      "description": "A SHA-256 digest serialized as lowercase `sha256:<hex>` text.",
      "maxLength": 71,
      "minLength": 71,
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "TransformRebindingFormatVersion": {
      "enum": [
        "1"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Static semantic-transform authority declared by one adapter artifact.\n\nThis transport does not authenticate the authority artifact. Consumers must establish trust\nin the exact serialized artifact through the separate canonical authority path.",
  "properties": {
    "adapter_content_digest": {
      "$ref": "#/$defs/Sha256Digest"
    },
    "adapter_id": {
      "$ref": "#/$defs/AdapterId"
    },
    "family": {
      "$ref": "#/$defs/ApplicationFamilyId"
    },
    "format_version": {
      "$ref": "#/$defs/TransformRebindingFormatVersion"
    },
    "rules": {
      "additionalProperties": false,
      "maxProperties": 128,
      "minProperties": 1,
      "patternProperties": {
        "^(?!.*\\.\\.)[a-z0-9](?:[a-z0-9._-]{0,253}[a-z0-9])?$": {
          "$ref": "#/$defs/AuthorizedTransformRuleRef"
        }
      },
      "type": "object"
    }
  },
  "required": [
    "format_version",
    "adapter_id",
    "family",
    "adapter_content_digest",
    "rules"
  ],
  "title": "AdapterTransformAuthority",
  "type": "object"
}
