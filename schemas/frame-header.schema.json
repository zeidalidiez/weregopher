  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Logical protocol frame header with an explicit, padding-free wire codec.",
  "properties": {
    "flags": {
      "description": "Versioned frame flags.",
      "format": "uint8",
      "maximum": 0,
      "minimum": 0,
      "type": "integer"
    },
    "frame_length": {
      "description": "Payload length in bytes, excluding this header.",
      "format": "uint32",
      "maximum": 4294967295,
      "minimum": 0,
      "type": "integer"
    },
    "message_kind": {
      "$ref": "#/$defs/MessageKind",
      "description": "Payload message category."
    },
    "protocol_major": {
      "description": "Incompatible protocol generation.",
      "format": "uint16",
      "maximum": 65535,
      "minimum": 0,
      "type": "integer"
    },
    "protocol_minor": {
      "description": "Additive negotiated protocol generation.",
      "format": "uint16",
      "maximum": 65535,
      "minimum": 0,
      "type": "integer"
    },
    "request_id": {
      "description": "Request/response correlation ID; zero means uncorrelated.",
      "format": "uint64",
      "maximum": 18446744073709551615,
      "minimum": 0,
      "type": "integer"
    },
    "sequence": {
      "description": "Monotonically increasing sequence number for one direction.",
      "format": "uint64",
      "maximum": 18446744073709551615,
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "frame_length",
    "protocol_major",
    "protocol_minor",
    "message_kind",
    "flags",
    "request_id",
    "sequence"
  ],
  "title": "FrameHeader",
  "type": "object"
}
